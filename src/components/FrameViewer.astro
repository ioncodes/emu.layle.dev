---
---

<div
  id="frame-viewer"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Screenshot viewer"
>
  <img
    id="frame-viewer-img"
    class="max-h-[95vh] max-w-[95vw] object-contain"
    alt=""
  />
  <div
    id="frame-viewer-indicator"
    class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded bg-black/60 px-2 py-1 font-mono text-xs text-white"
  >
  </div>
  <button
    id="frame-viewer-close"
    class="absolute top-4 right-4 rounded bg-black/60 px-2 py-1 text-xs text-white hover:bg-black/80"
    aria-label="Close"
  >
    ✕
  </button>
</div>

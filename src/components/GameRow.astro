---
import type { GameRow } from "@/lib/meta";

interface Props {
  row: GameRow;
}

const { row } = Astro.props;
const hasFrames = row.frames.length > 0;
---

<li
  class="game-row"
  data-game-id={row.game.game_id}
  data-title={row.game.game_title}
  data-has-frames={hasFrames}
>
  <h2 class="flex items-baseline gap-3 text-sm">
    <span class="font-medium">{row.game.game_title}</span>
    <span class="font-mono text-xs text-neutral-500">{row.game.game_id}</span>
    {
      row.frames.length > 1 && (
        <span class="ml-auto text-xs text-neutral-500">{row.frames.length} frames</span>
      )
    }
  </h2>
  {
    hasFrames ? (
      <div class="frames-container mt-2 flex gap-2 overflow-x-auto pb-2" style="min-height:140px" />
    ) : (
      <p class="mt-2 text-sm italic text-neutral-500">No screenshots available</p>
    )
  }
</li>

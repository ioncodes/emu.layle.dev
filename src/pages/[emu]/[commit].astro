---
import { getCommits, getEmulators, getGameRows, getSubmission } from "@/lib/meta";
import { siteConfig } from "../../../site.config";
import GameRow from "@/components/GameRow.astro";
import FrameViewer from "@/components/FrameViewer.astro";
import CommitNav from "@/components/CommitNav.astro";
import EmulatorTabs from "@/components/EmulatorTabs.astro";
import "../../styles/global.css";

export function getStaticPaths() {
  const paths: { params: { emu: string; commit: string } }[] = [];
  for (const emu of getEmulators()) {
    for (const sub of getCommits(emu.slug)) {
      paths.push({ params: { emu: emu.slug, commit: sub.commit_short } });
    }
  }
  return paths;
}

const { emu, commit } = Astro.params;
const allEmulators = getEmulators();
const emulator = allEmulators.find((e) => e.slug === emu);
const submission = getSubmission(emu!, commit!);
if (!emulator || !submission) {
  throw new Error(`no submission ${emu}/${commit}`);
}
const rows = getGameRows(emu!, commit!);
const allCommits = getCommits(emu!);
const commitUrl = emulator.commit_url_template.replace("{sha}", submission.commit);
const framesTotal = submission.screenshots.length;
const gamesTotal = submission.games.length;
const gamesWithFrames = new Set(submission.screenshots.map((s) => s.game_id)).size;

const framesData = rows
  .filter((r) => r.frames.length > 0)
  .map((r) => ({
    game_id: r.game.game_id,
    frames: r.frames.map((f) => ({
      src: `${siteConfig.screenshotsBaseUrl}/${f.r2_key}`,
      w: f.width,
      h: f.height,
      i: f.frame_index,
    })),
  }));
---

<!doctype html>
<html lang="en" class="bg-white text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{emulator.name} / {submission.commit_short}</title>
  </head>
  <body class="min-h-screen font-sans antialiased">
    <div class="border-b border-neutral-200 dark:border-neutral-800">
      <div class="mx-auto max-w-6xl px-6 py-4">
        <EmulatorTabs emulators={allEmulators} currentSlug={emu!} />
      </div>
    </div>

    <main class="mx-auto max-w-6xl px-6 py-8">
      <header class="mb-8 border-b border-neutral-200 pb-6 dark:border-neutral-800">
        <div class="flex flex-wrap items-center gap-4">
          <a
            href={commitUrl}
            class="font-mono text-sm text-neutral-600 hover:underline dark:text-neutral-400"
            target="_blank"
            rel="noreferrer"
          >
            {submission.commit_short}
          </a>
          <span class="text-xs text-neutral-500">{submission.commit_timestamp}</span>
          <CommitNav emu={emu!} current={submission} allCommits={allCommits} />
          <input
            id="game-filter"
            type="search"
            placeholder="Filter games..."
            aria-label="Filter games by title or id"
            class="ml-auto w-64 max-w-full rounded border border-neutral-300 bg-white px-3 py-1 text-sm outline-none focus:border-neutral-500 dark:border-neutral-700 dark:bg-neutral-900"
          />
        </div>
        <p class="mt-3 text-sm text-neutral-700 dark:text-neutral-300">
          {submission.commit_message}
        </p>
        <p class="mt-2 text-xs text-neutral-500">
          {gamesTotal} games, {gamesWithFrames} with screenshots, {framesTotal} frames
        </p>
      </header>

      <ul class="space-y-10">
        {rows.map((row) => <GameRow row={row} />)}
      </ul>
    </main>

    <FrameViewer />

    <script is:inline type="application/json" id="frames-data" set:html={JSON.stringify(framesData)} />
    <script>
      import "../../scripts/commit-view";
    </script>
  </body>
</html>
